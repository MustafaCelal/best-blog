---
const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title} | The Trio Blog</title>
    <style is:global>
        :root {
            --primary: #6366f1;
            --bg: #0f172a;
            --surface: #1e293b;
            --text: #f8fafc;
            --text-dim: #94a3b8;
        }
        body {
            font-family: 'Outfit', sans-serif;
            background: var(--bg);
            color: var(--text);
            margin: 0;
            line-height: 1.6;
        }
        header {
            padding: 2rem 0;
            border-bottom: 1px solid var(--surface);
            margin-bottom: 3rem;
        }
        .container {
            max-width: 900px;
            margin: 0 auto;
            width: 90%;
        }
        h1, h2, h3 { color: var(--text); font-weight: 700; }
        a { color: var(--primary); text-decoration: none; transition: 0.2s; }
        a:hover { opacity: 0.8; }
        .post-card {
            background: var(--surface);
            padding: 2rem;
            border-radius: 1rem;
            margin-bottom: 2rem;
            border: 1px solid #334155;
            transition: transform 0.2s;
        }
        .post-card:hover { transform: translateY(-5px); border-color: var(--primary); }
    </style>
</head>
<body>
    <header>
        <div class="container">
            <nav>
                <a href="/" style="font-size: 1.5rem; font-weight: 900; color: white;">THE TRIO</a>
            </nav>
        </div>
    </header>
    <main class="container">
        <slot />
    </main>
    <footer class="container" style="margin-top: 5rem; padding-bottom: 3rem; border-top: 1px solid var(--surface); padding-top: 2rem; color: var(--text-dim);">
        <p>&copy; 2024 The Trio Blog - Ultra Performance Showcase</p>
    </footer>
</body>
</html>
