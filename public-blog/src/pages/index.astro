---
import Layout from '../layouts/Layout.astro';
import PocketBase from 'pocketbase';

const pb = new PocketBase('http://backend:8080');
let posts = [];

try {
  posts = await pb.collection('posts').getFullList({
    sort: '-created',
    filter: 'status = "published"'
  });
} catch (e) {
  console.error("PocketBase connection error:", e);
}
---

<Layout title="Ana Sayfa">
    <section>
        <h1 style="font-size: 3rem; margin-bottom: 2rem;">Son Yazılar</h1>
        
        {posts.length === 0 && (
            <div class="post-card">
                <p>Henüz yazı yayınlanmamış. Admin panelinden ilk yazınızı ekleyin!</p>
            </div>
        )}

        {posts.map((post) => (
            <article class="post-card">
                <h2>{post.title}</h2>
                <div style="color: var(--text-dim); margin-bottom: 1rem;">
                    {new Date(post.created).toLocaleDateString('tr-TR')}
                </div>
                <p>{post.excerpt || post.content.replace(/<[^>]*>/g, '').substring(0, 150)}...</p>
                <a href={`/post/${post.slug}`}>Devamını Oku &rarr;</a>
            </article>
        ))}
    </section>
</Layout>
